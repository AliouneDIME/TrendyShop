# ─── Frontend ────────────────────────────────────────
# Vite exposes only VITE_ prefixed vars to the browser
VITE_APP_NAME=TrendyShop
VITE_APP_URL=https://trendyshop.sn

# ─── Backend ─────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# ─── PayTech.sn ──────────────────────────────────────
# Get your keys at: https://paytech.sn/dashboard
# NEVER expose these in frontend code - backend only!
PAYTECH_API_KEY=5b2eaca2cef825cb5e1a40533b393849b55820bf09a88526d6b4501ba45129f4
PAYTECH_API_SECRET=3bc1a32d8d626fb4fdcb961568fb264a4091a3bd10a79928c9263eea6d2d8146

# ─── Orange Money API (optional) ─────────────────────
ORANGE_MONEY_API_KEY=your_orange_money_key
ORANGE_MONEY_CLIENT_ID=your_client_id
ORANGE_MONEY_CLIENT_SECRET=your_client_secret

# ─── Wave API (optional) ─────────────────────────────
WAVE_API_KEY=your_wave_api_key

# ─── Database (for production) ───────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/trendyshop

# ─── Security ────────────────────────────────────────
SESSION_SECRET=generate_a_long_random_string_here
JWT_SECRET=another_long_random_string_here

# ─── Email (for order confirmations) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# ─── Analytics ───────────────────────────────────────
VITE_GA_ID=G-XXXXXXXXXX
