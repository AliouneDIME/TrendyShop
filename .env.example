# ─── Frontend (variables exposées au navigateur — préfixe VITE_ obligatoire) ──
VITE_APP_NAME=TrendyShop
VITE_APP_URL=https://trendyshop.sn
# GA4 (optionnel)
VITE_GA_ID=G-XXXXXXXXXX

# ─── Backend Node.js (JAMAIS exposées au navigateur) ─────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=https://trendyshop.sn
BACKEND_URL=https://api.trendyshop.sn

# ─── PayTech.sn ──────────────────────────────────────────────────────────────
# ⚠️  Ces clés NE DOIVENT JAMAIS apparaître dans src/ ou être préfixées VITE_
# Obtenez-les sur : https://paytech.sn/dashboard
PAYTECH_API_KEY=votre_api_key_paytech_ici
PAYTECH_API_SECRET=votre_api_secret_paytech_ici
# Secret HMAC pour valider les notifications IPN de PayTech
PAYTECH_IPN_SECRET=votre_secret_ipn_ici

# ─── Orange Money (optionnel) ────────────────────────────────────────────────
ORANGE_MONEY_API_KEY=votre_orange_money_key
ORANGE_MONEY_CLIENT_ID=votre_client_id
ORANGE_MONEY_CLIENT_SECRET=votre_client_secret

# ─── Wave (optionnel) ────────────────────────────────────────────────────────
WAVE_API_KEY=votre_wave_api_key

# ─── Base de données (production) ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/trendyshop

# ─── Sécurité ─────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=changez-moi-32-caracteres-aleatoires-minimum
JWT_SECRET=changez-moi-aussi-32-caracteres-minimum

# ─── Email (confirmations commandes) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe_application
